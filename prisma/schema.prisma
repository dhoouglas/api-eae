
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  
  pushToken String?  @unique
  notifyOnNewEvents      Boolean  @default(true)
  notifyOnEventReminders Boolean  @default(true)
  notifyOnNews           Boolean  @default(true)

  attendances   EventAttendance[]
  notifications Notification[]
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String
  imageUrl    String?  

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendees   EventAttendance[]

  @@map("events")
}

model EventAttendance {
  userId    String
  eventId   String
  status    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, eventId])
  @@map("event_attendances")
}

model NewsPost {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text // @db.Text é ideal para textos mais longos
  category  String   // Ex: "CONSERVAÇÃO", "EDUCAÇÃO", "EVENTO"
  imageUrl  String?  // A imagem da notícia será opcional

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news_posts")
}

model Notification {
  id       String   @id @default(uuid())
  title    String
  message  String
  category String   // "GERAL", "EVENTO", "LEMBRETE"
  read     Boolean  @default(false)
  entityId String?  // ID do evento ou entidade relacionada

  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("notifications")
}

model Fauna {
  id        String   @id @default(uuid())
  name      String
  scientificName String
  description String @db.Text
  habitat   String
  conservationStatus String
  imageUrls  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faunas")
}

model Flora {
  id        String   @id @default(uuid())
  name      String
  scientificName String
  description String @db.Text
  family    String
  conservationStatus String
  imageUrls  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("floras")
}

enum TrailDifficulty {
  FACIL
  MEDIO
  DIFICIL
}

enum TrailStatus {
  ABERTA
  FECHADA
  MANUTENCAO
}

enum TrailType {
  CAMINHADA
  CICLISMO
  MISTA
}

model Trail {
  id              String   @id @default(uuid())
  name            String
  description     String   @db.Text
  distance        Float
  difficulty      TrailDifficulty
  estimatedTime   Int // in minutes
  imageUrls       String[]
  status          TrailStatus @default(ABERTA)
  type            TrailType
  elevationGain   Float

  coordinates     TrailCoordinate[]
  waypoints       TrailWaypoint[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("trails")
}

model TrailCoordinate {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  order     Int

  trail     Trail    @relation(fields: [trailId], references: [id], onDelete: Cascade)
  trailId   String

  waypoint  TrailWaypoint?

  @@map("trail_coordinates")
}

model TrailWaypoint {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  imageUrl    String?

  trail       Trail    @relation(fields: [trailId], references: [id], onDelete: Cascade)
  trailId     String

  coordinate   TrailCoordinate @relation(fields: [coordinateId], references: [id], onDelete: Cascade)
  coordinateId String          @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("trail_waypoints")
}
